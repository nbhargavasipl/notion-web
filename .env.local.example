# Firebase project config — Firebase console → Project settings → Your apps → Web app
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your-project-id
NEXT_PUBLIC_FIREBASE_APP_ID=

# For local dev only — Cloud Run uses Application Default Credentials automatically.
# Download from GCloud console → IAM → Service accounts → your SA → Keys → Add key
GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json
