# ── Application mode ───────────────────────────────────────────────────────────
# "demo"       → free Gemini tier; paid APIs blocked; safe for public demos
# "production" → paid APIs allowed; requires Google Speech credentials
MOSAIC_APP_MODE=demo

# ── Transcription provider ─────────────────────────────────────────────────────
# "gemini"        → Gemini multimodal (free tier in demo mode)
# "google_speech" → Google Cloud Speech Chirp-2 (paid; production mode only)
TRANSCRIPTION_PROVIDER=gemini
TRANSLATION_PROVIDER=gemini
# "gemini" → Gemini (free tier); "claude" → Claude via Anthropic API
SUMMARY_PROVIDER=gemini

# ── Billing / safety ───────────────────────────────────────────────────────────
# Must be "false" in demo mode — enforced by config validation
ALLOW_PAID_FALLBACK=false

# ── Gemini (required when TRANSCRIPTION_PROVIDER=gemini or TRANSLATION_PROVIDER=gemini or SUMMARY_PROVIDER=gemini)
# Get a key at: https://aistudio.google.com/apikey
# NEVER commit a real key. Keep this file value blank or use a placeholder.
GEMINI_API_KEY=
GEMINI_TRANSCRIPTION_MODEL=gemini-2.0-flash
GEMINI_SUMMARY_MODEL=gemini-2.0-flash

# ── Claude / Anthropic (required when SUMMARY_PROVIDER=claude) ─────────────────
# Get a key at: https://console.anthropic.com/
ANTHROPIC_API_KEY=
# Optional: override the default model (claude-haiku-4-5-20251001)
CLAUDE_SUMMARY_MODEL=claude-haiku-4-5-20251001

# ── Google Speech proxy (required when TRANSCRIPTION_PROVIDER=google_speech) ──
# URL and master key for the MOSAIC-Transcript Cloud Run service
TRANSCRIPTION_API_URL=
TRANSCRIPTION_MASTER_KEY=

# ── Demo mode limits ───────────────────────────────────────────────────────────
DEMO_MAX_RECORDING_MINUTES=60
DEMO_MAX_PROCESSING_MINUTES_PER_DAY=180
DEMO_MAX_RECORDINGS_PER_DAY=10
DEMO_MAX_UPLOAD_MB=100
DEMO_PROCESSING_RETRY_LIMIT=2
DEMO_AUDIO_RETENTION_DAYS=3

# ── Firebase (public — safe to expose in client bundles) ───────────────────────
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# ── GCS signed-URL endpoint ────────────────────────────────────────────────────
NEXT_PUBLIC_SIGNED_URL_API=

# ── NOT ALLOWED — never add these ─────────────────────────────────────────────
# NEXT_PUBLIC_GEMINI_API_KEY=      ← leaks key to browser bundle
# NEXT_PUBLIC_OPENAI_API_KEY=      ← leaks key to browser bundle
# NEXT_PUBLIC_DEEPGRAM_API_KEY=    ← leaks key to browser bundle
